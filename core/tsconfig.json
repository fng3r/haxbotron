{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ES2024"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "rootDir": ".",
    "outDir": "out",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "noEmitOnError": true,
    "sourceMap": true,
    "incremental": true,
    "tsBuildInfoFile": "out/.tsbuildinfo",
    "removeComments": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "api/**/*.ts",
    "game/**/*.ts",
    "lib/**/*.ts",
    "typings/**/*.d.ts",
    "app.ts",
    "winstonLoggerSystem.ts"
  ],
  "exclude": ["node_modules", "out", "test"]
}
